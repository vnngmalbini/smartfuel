# Runtime (required)
SECRET_KEY=your-secret-key-here-change-in-production
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# Runtime (recommended)
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
SITE_BASE_URL=http://127.0.0.1:8000

# Email transport (used for receipt delivery)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@smartfuel.com

# SMS receipt delivery (Twilio-compatible)
SMS_ENABLED=False
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional: Google script/social app setup
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/accounts/google/login/callback/

# Optional/Future (currently not read by runtime settings)
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=smartfuel_db
DB_USER=smartfuel_user
DB_PASSWORD=secure_password_here
DB_HOST=localhost
DB_PORT=5432

# Additional payment provider
STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# Redis/Cache
REDIS_URL=redis://localhost:6379/0

# AWS S3 storage
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# Sentry error tracking
SENTRY_DSN=

# Security flags
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
